// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - id: string (required)
//   - role: string (required, ['factory', 'center', 'monitor'])
//   - code: string (required)
//   - username: string (required)
//   - password: string (required)
//   - displayName: string (required)
//
// Collection: palletTypes
// Document ID: {typeId}
// Fields:
//   - id: string (required)
//   - stageCode: string (required)
//   - stageName: string (required)
//   - cartonsPerPallet: number (required)
//   - bundlesPerCarton: number (required)
//
// Collection: trips
// Document ID: {tripId}
// Fields:
//   - id: string (required)
//   - tripNumber: string (required)
//   - tripBarcode: string (required)
//   - pressCode: string (required)
//   - centerCode: string (required)
//   - startDate: number (required)
//   - status: string (required, ['active', 'completed'])
//
// Collection: records
// Document ID: {recordId}
// Fields:
//   - id: string (required)
//   - palletTypeId: string (required)
//   - palletBarcode: string (required)
//   - tripId: string (required)
//   - truckId: string (optional)
//   - status: string (required, ['pending', 'in_transit', 'received'])
//   - timestamp: number (required)
//   - factoryTimestamp: number (optional)
//   - centerTimestamp: number (optional)
//   - scannedBy: string (required)
//   - destination: string (required)
//   - condition: string (optional)
//   - externalDamageQty: number (optional)
//   - internalDamageQty: number (optional)
//   - photos: list (optional)
//   - notes: string (optional)
//   - damageDetails: string (optional)
//
// Collection: config
// Document ID: system
// Fields:
//   - lastResetTimestamp: number (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         (request.auth.token.email == "m0931700446@gmail.com" && request.auth.token.email_verified == true)); 
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /palletTypes/{typeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /trips/{tripId} {
      allow read: if true;
      allow write: if true;
    }

    match /records/{recordId} {
      allow read: if true;
      allow write: if true;
    }

    match /config/{docId} {
      allow read: if true;
      allow write: if true;
    }

    match /distributionTrips/{tripId} {
      allow read: if true;
      allow write: if true;
    }

    match /system_logs/{logId} {
      allow read: if true;
      allow write: if true;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
