{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user with role-based access",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "password": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["factory", "center", "monitor", "admin"] },
        "code": { "type": "string" }
      },
      "required": ["id", "username", "role", "code"]
    },
    "PalletType": {
      "title": "Pallet Type",
      "description": "Definition of pallet stages and capacities",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "stageCode": { "type": "string" },
        "stageName": { "type": "string" },
        "cartonsPerPallet": { "type": "number" },
        "bundlesPerCarton": { "type": "number" }
      },
      "required": ["id", "stageCode", "stageName", "cartonsPerPallet", "bundlesPerCarton"]
    },
    "Trip": {
      "title": "Trip",
      "description": "Logistical trip involving pallet transport",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tripNumber": { "type": "string" },
        "tripBarcode": { "type": "string" },
        "pressCode": { "type": "string" },
        "centerCode": { "type": "string" },
        "startDate": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "completed"] }
      },
      "required": ["id", "tripNumber", "tripBarcode", "status"]
    },
    "Record": {
      "title": "Record",
      "description": "Individual pallet scan record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "palletTypeId": { "type": "string" },
        "palletBarcode": { "type": "string" },
        "tripId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in_transit", "received"] },
        "timestamp": { "type": "number" },
        "scannedBy": { "type": "string" },
        "destination": { "type": "string" }
      },
      "required": ["id", "palletTypeId", "palletBarcode", "tripId", "status", "timestamp", "scannedBy"]
    },
    "SystemLog": {
      "title": "System Log",
      "description": "Audit trail for system actions",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "number" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "Users" },
    "/palletTypes/{typeId}": { "schema": "PalletType", "description": "Pallet configurations" },
    "/trips/{tripId}": { "schema": "Trip", "description": "Trip logs" },
    "/records/{recordId}": { "schema": "Record", "description": "Scan records" },
    "/distributionTrips/{tripId}": { "schema": "Trip", "description": "Local distribution logs" },
    "/system_logs/{logId}": { "schema": "SystemLog", "description": "Audit trail" },
    "/config/{docId}": { "schema": "object", "description": "System config" }
  }
}
